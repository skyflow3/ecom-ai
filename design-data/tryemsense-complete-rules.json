{
  ".adv-him-button": ".adv-him-button{color:#fff;text-align:center;background-color:#47901a;border-radius:8px;margin-left:auto;margin-right:auto;padding:12px 24px;font-family:Poppins,sans-serif;font-size:24px;font-weight:700;line-height:32px;text-decoration:none;transition:transform .2s ease-in-out,background-color .2s ease-in-out;display:block}",
  ".adv-5r-btn": ".adv-5r-btn{text-align:center;text-transform:uppercase;background-color:#00c249;border-radius:8px;width:100%;max-width:410px;height:auto;padding:16px;font-family:Open Sans,sans-serif;font-size:18px;font-weight:800;line-height:24px;transition:all .2s}",
  ".adv-heading-1-5r": ".adv-heading-1-5r{color:#02122e;margin-top:0;margin-bottom:0;font-family:Open Sans,sans-serif;font-size:40px;font-weight:800;line-height:48px}",
  ".adv-him-section": ".adv-him-section{flex-flow:column;justify-content:center;align-items:center;padding:32px 16px 40px}",
  ".adv-him-layout": ".adv-him-layout{grid-column-gap:12px;grid-row-gap:12px;grid-template-rows:auto;grid-template-columns:1fr 300px;grid-auto-columns:1fr;align-items:start;display:grid}",
  ".adv-him-main": ".adv-him-main{background-color:#fff;padding:24px 16px}",
  ".adv-him-container": ".adv-him-container{max-width:1100px}",
  ".adv-him-aside": ".adv-him-aside{background-color:#fff;padding:12px}",
  ".adv-right-column": ".adv-right-column{width:100%;max-width:352px;display:block}",
  ".adv-left-column": ".adv-left-column{flex-flow:column;width:100%;max-width:760px;display:flex}",
  ".ad11-hero": ".ad11-hero{color:#fff;background-image:url(https://cdn.prod.website-files.com/6819b366c1749c40aae27841/693a7bd1eb40ad768e545e4a_INT%20AD11%20Hero%20bg.avif);background-position:50%;background-size:cover}",
  ".adv-him-cta": ".adv-him-cta{grid-column-gap:20px;grid-row-gap:20px;border:2px solid #da4b8b;border-radius:2px;flex-flow:column;margin-bottom:20px;padding:20px;display:flex}",
  ".adv-him-breadcrumbs": ".adv-him-breadcrumbs{grid-column-gap:8px;grid-row-gap:8px;align-items:center;margin-bottom:16px;font-family:Poppins,sans-serif;font-size:16px;line-height:24px;display:flex}",
  ".adv-him-timestamp": ".adv-him-timestamp{grid-column-gap:8px;grid-row-gap:8px;justify-content:flex-start;align-items:flex-end;margin-bottom:16px;font-family:Poppins,sans-serif;display:flex}",
  ".adv-him-custom-list": ".adv-him-custom-list{grid-column-gap:8px;grid-row-gap:8px;flex-flow:column;margin-bottom:20px;margin-left:24px;display:flex}",
  ".adv-him-custom-list-item": ".adv-him-custom-list-item{grid-column-gap:8px;grid-row-gap:8px;align-items:flex-start;list-style-type:disc;display:flex}",
  ".adv-him-embeded-video-container": ".adv-him-embeded-video-container{aspect-ratio:16/9;width:100%;height:auto}",
  ".adv-him-text-cta": ".adv-him-text-cta{grid-column-gap:20px;grid-row-gap:20px;text-align:center;flex-flow:column;margin-bottom:20px;display:flex}",
  ".adv-him-text-cta-link": ".adv-him-text-cta-link{color:#00e;font-family:Poppins,sans-serif;font-size:26px;font-weight:600;line-height:34px}",
  ".adv-money-back-block": ".adv-money-back-block{grid-column-gap:16px;grid-row-gap:16px;background-color:#fffbef;border:1px solid #fab73c;border-radius:8px;justify-content:flex-start;align-items:center;padding:16px;display:flex}",
  ".adv-him-limited": ".adv-him-limited{background-color:#fefbc3;border:2px dashed #d0021b;margin-bottom:20px;padding:12px}",
  ".adv-footer-disclaimer": ".adv-footer-disclaimer{color:#00000080;text-align:center;max-width:1100px;margin-left:auto;margin-right:auto}",
  ".adv-him-red-underline": ".adv-him-red-underline{color:red;text-decoration:underline}",
  ".adv-him-h2-highlight": ".adv-him-h2-highlight{background-color:#fdcc5e}",
  ".adv-him-img": ".adv-him-img{width:100%}",
  ".adv-him-img-caption": ".adv-him-img-caption{text-align:center;background-color:#fdcc5e;padding:8px;font-size:20px;line-height:28px}"
}