{
  "name": "ecom-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "docker:build": "docker build -t ecom-ai .",
    "docker:run": "docker run -p 3000:3000 --env-file .env ecom-ai"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@clerk/nextjs": "^6.19.0",
    "@react-email/components": "^0.0.41",
    "@tanstack/react-query": "^5.76.0",
    "@upstash/ratelimit": "^2.0.0",
    "@upstash/redis": "^1.34.0",
    "bullmq": "^5.53.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "drizzle-orm": "^0.43.0",
    "ioredis": "^5.6.0",
    "lucide-react": "^0.511.0",
    "next": "^15.3.0",
    "postgres": "^3.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "resend": "^4.5.0",
    "stripe": "^18.0.0",
    "svix": "^1.92.2",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.5"
  }
}
