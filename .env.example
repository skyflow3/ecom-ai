# ═══════════════════════════════════════
# ECOM-AI — Environment Variables
# ═══════════════════════════════════════
# Copy to .env and fill in values.
# Missing required vars = crash at startup.

# ── Database ──
DATABASE_URL=postgresql://user:pass@localhost:5432/ecom_ai

# ── Auth (Clerk) ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── Redis (Upstash) ──
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ── Email (Resend) ──
RESEND_API_KEY=re_...

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── BullMQ (same Redis) ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Meta API ──
META_ACCESS_TOKEN=...
META_AD_ACCOUNT_ID=act_...
META_APP_ID=...
META_APP_SECRET=...

# ── AI Content Production (optional) ──
MIMO_API_KEY=
MIMO_API_URL=https://api.mimo.vn/v1/chat/completions
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# ── Storage (optional) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
